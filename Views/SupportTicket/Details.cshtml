@model DSM.Models.SupportTicket

@{
    ViewData["Title"] = "SupportTicket Details";
}

<section class="workspace-grid">
    <section class="confirm-toast details-card">
        <span>SupportTicket details</span>
        <h2>@Html.DisplayFor(model => model.Subject)</h2>
        <p class="delete-warning">Manage support tickets, categories, priorities and status.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.Subject)</span>
                    <strong>@Html.DisplayFor(model => model.Subject)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Description)</span>
                    <strong>@Html.DisplayFor(model => model.Description)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Category)</span>
                    <strong class="status-pill">@Html.DisplayFor(model => model.Category)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Priority)</span>
                    <strong class="status-pill">@Html.DisplayFor(model => model.Priority)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Status)</span>
                    <strong class="status-pill">@Html.DisplayFor(model => model.Status)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.RequesterId)</span>
                    <strong>@Html.DisplayFor(model => model.RequesterId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.RequesterName)</span>
                    <strong>@Html.DisplayFor(model => model.RequesterName)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.RequesterEmail)</span>
                    <strong>@Html.DisplayFor(model => model.RequesterEmail)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.AssignedUserId)</span>
                    <strong>@Html.DisplayFor(model => model.AssignedUserId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.AssignedUserName)</span>
                    <strong>@Html.DisplayFor(model => model.AssignedUserName)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.UpdatedAt)</strong>
                </div>
        </section>

        <div class="form-actions">
            <a asp-action="Index" class="secondary-button">Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="primary-button">Edit</a>
        </div>
    </section>
</section>
