@model IEnumerable<DSM.Models.SupportTicket>

@{
    ViewData["Title"] = "Support";
}

<section class="workspace-grid">
    <section class="workspace-table dsm-list-panel" data-dsm-list>
        <div class="table-head">
            <div>
                <h2>Support</h2>
                <p>Manage support tickets, categories, priorities and status.</p>
            </div>

            <div class="table-filters">
                <span class="filter-leading-icon" aria-hidden="true"><i class="pi pi-search"></i></span>
                <input class="dsm-search-input" type="search" placeholder="Search support" aria-label="Search support" />
                <button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear" aria-label="Clear search">
                    <i class="pi pi-times"></i>
                </button>
            </div>

            <a asp-action="Create" class="icon-button create-action" data-tooltip="New SupportTicket" aria-label="New SupportTicket">
                <i class="pi pi-plus"></i>
            </a>
        </div>

        @if (!Model.Any()) {
            <div class="empty-state">
                <strong>No support found.</strong>
                <span>Add a new record to begin.</span>
                <a asp-action="Create" class="primary-button">New SupportTicket</a>
            </div>
        } else {
            <div class="dsm-rows">
@foreach (var item in Model) {
                <div class="row-shell dsm-search-row">
                    <article class="table-row">
                        <div>
                            <strong>@Html.DisplayFor(modelItem => item.Subject)</strong>
                            <span>@Html.DisplayFor(modelItem => item.Description)</span>
                        </div>

                        <div class="row-metrics">
                            <span class="dsm-chip"><span class="status-pill">@Html.DisplayFor(modelItem => item.Category)</span></span>
                            <span class="dsm-chip"><span class="status-pill">@Html.DisplayFor(modelItem => item.Priority)</span></span>
                            <span class="dsm-chip"><span class="status-pill">@Html.DisplayFor(modelItem => item.Status)</span></span>
                        </div>

                        <div class="row-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details" aria-label="Details">
                                <i class="pi pi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit" aria-label="Edit">
                                <i class="pi pi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete" aria-label="Delete">
                                <i class="pi pi-trash"></i>
                            </a>
                        </div>

                        <span class="row-chevron"><i class="pi pi-chevron-down"></i></span>
                    </article>

                    <section class="row-detail static-detail">
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Subject)</span>
                            <strong>@Html.DisplayFor(modelItem => item.Subject)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Description)</span>
                            <strong>@Html.DisplayFor(modelItem => item.Description)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Category)</span>
                            <strong><span class="status-pill">@Html.DisplayFor(modelItem => item.Category)</span></strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Priority)</span>
                            <strong><span class="status-pill">@Html.DisplayFor(modelItem => item.Priority)</span></strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Status)</span>
                            <strong><span class="status-pill">@Html.DisplayFor(modelItem => item.Status)</span></strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.RequesterId)</span>
                            <strong>@Html.DisplayFor(modelItem => item.RequesterId)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.RequesterName)</span>
                            <strong>@Html.DisplayFor(modelItem => item.RequesterName)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.RequesterEmail)</span>
                            <strong>@Html.DisplayFor(modelItem => item.RequesterEmail)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.AssignedUserId)</span>
                            <strong>@Html.DisplayFor(modelItem => item.AssignedUserId)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.AssignedUserName)</span>
                            <strong>@Html.DisplayFor(modelItem => item.AssignedUserName)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <strong>@Html.DisplayFor(modelItem => item.CreatedAt)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <strong>@Html.DisplayFor(modelItem => item.UpdatedAt)</strong>
                        </div>
                    </section>
                </div>
}
            </div>
        }
    </section>
</section>
