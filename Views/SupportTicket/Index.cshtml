@model IEnumerable<DSM.Models.SupportTicket>
@{ ViewData["Title"] = "Support"; }
<section class="workspace-grid"><section class="workspace-table dsm-list-panel" data-dsm-list><div class="table-head"><div><h2>Support</h2><p>Manage support, access and account activation tickets.</p></div><div class="table-filters"><span class="filter-leading-icon"><i class="pi pi-search"></i></span><input class="dsm-search-input" type="search" placeholder="Search support" /><button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear"><i class="pi pi-times"></i></button></div><a asp-action="Create" class="icon-button create-action" data-tooltip="New Ticket"><i class="pi pi-plus"></i></a></div>
@if (!Model.Any()) { <div class="empty-state"><strong>No tickets found.</strong><span>Create a support ticket.</span><a asp-action="Create" class="primary-button">New Ticket</a></div> } else { <div class="dsm-rows">@foreach (var item in Model) { <div class="row-shell dsm-search-row"><article class="table-row"><div><strong>@item.Subject</strong><span>@item.RequesterName @item.RequesterEmail</span></div><div class="row-metrics"><span class="status-pill">@item.Status</span><span class="dsm-chip">@item.Category</span><span class="dsm-chip">@item.Priority</span></div><div class="row-actions"><a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details"><i class="pi pi-eye"></i></a><a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit"><i class="pi pi-pencil"></i></a><a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete"><i class="pi pi-trash"></i></a></div><span class="row-chevron"><i class="pi pi-chevron-down"></i></span></article><section class="row-detail static-detail"><div><span>Description</span><strong>@item.Description</strong></div><div><span>Assigned</span><strong>@(item.AssignedUserName ?? "Unassigned")</strong></div></section></div> }</div> }
</section></section>
