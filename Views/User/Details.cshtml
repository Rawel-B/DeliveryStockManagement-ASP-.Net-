@model DSM.Models.User

@{
    ViewData["Title"] = "User Details";
}

<section class="workspace-grid">
    <section class="confirm-toast details-card">
        <span>User details</span>
        <h2>@Html.DisplayFor(model => model.Name)</h2>
        <p class="delete-warning">Manage workspace users, roles and access status.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.Username)</span>
                    <strong>@Html.DisplayFor(model => model.Username)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Password)</span>
                    <span class="muted-value">••••••</span>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Name)</span>
                    <strong>@Html.DisplayFor(model => model.Name)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Email)</span>
                    <strong>@Html.DisplayFor(model => model.Email)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Role)</span>
                    <strong class="status-pill">@Html.DisplayFor(model => model.Role)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.IsActive)</span>
                    @if (Model?.IsActive == true) {
                        <strong class="status-pill status-good">Active</strong>
                    } else {
                        <strong class="status-pill">Inactive</strong>
                    }
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
        </section>

        <div class="form-actions">
            <a asp-action="Index" class="secondary-button">Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="primary-button">Edit</a>
        </div>
    </section>
</section>
