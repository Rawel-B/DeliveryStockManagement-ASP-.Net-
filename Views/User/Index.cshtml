@model IEnumerable<DSM.Models.User>
@{ ViewData["Title"] = "Users"; }

<section class="workspace-grid">
    <section class="workspace-table dsm-list-panel" data-dsm-list>
        <div class="table-head">
            <div><h2>Users</h2></div>
            <div class="table-filters">
                <span class="filter-leading-icon"><i class="pi pi-search"></i></span>
                <input class="dsm-search-input" type="search" placeholder="Search users" />
                <button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear"><i class="pi pi-times"></i></button>
            </div>
            <a asp-action="Create" class="icon-button create-action" data-tooltip="New User"><i class="pi pi-plus"></i></a>
        </div>

        @if (!Model.Any()) {
            <div class="dsm-rows"></div>
        } else {
            <div class="dsm-rows">
                @foreach (var item in Model) {
                    <div class="row-shell dsm-search-row">
                        <article class="table-row">
                            <div>
                                <strong>@item.Username</strong>
                                <span>@item.Name - @item.Email</span>
                            </div>
                            <div class="row-metrics">
                                <span class="status-pill">@item.Role</span>
                                <span class="state-chip @(item.IsActive ? "is-active" : "is-inactive")">@(item.IsActive ? "Active" : "Inactive")</span>
                            </div>
                            <div class="row-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details"><i class="pi pi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit"><i class="pi pi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete"><i class="pi pi-trash"></i></a>
                            </div>
                            <span class="row-chevron"><i class="pi pi-chevron-down"></i></span>
                        </article>
                        <section class="row-detail static-detail">
                            <div><span>Name</span><strong>@item.Name</strong></div>
                            <div><span>Email</span><strong>@item.Email</strong></div>
                            <div><span>Role</span><strong>@item.Role</strong></div>
                            <div><span>Active</span><strong class="state-chip @(item.IsActive ? "is-active" : "is-inactive")">@(item.IsActive ? "Active" : "Inactive")</strong></div>
                        </section>
                    </div>
                }
            </div>
        }
    </section>
</section>
