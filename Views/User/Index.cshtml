@model IEnumerable<DSM.Models.User>

@{
    ViewData["Title"] = "Users";
}

<section class="workspace-grid">
    <section class="workspace-table dsm-list-panel" data-dsm-list>
        <div class="table-head">
            <div>
                <h2>Users</h2>
                <p>Manage workspace users, roles and access status.</p>
            </div>

            <div class="table-filters">
                <span class="filter-leading-icon" aria-hidden="true"><i class="pi pi-search"></i></span>
                <input class="dsm-search-input" type="search" placeholder="Search users" aria-label="Search users" />
                <button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear" aria-label="Clear search">
                    <i class="pi pi-times"></i>
                </button>
            </div>

            <a asp-action="Create" class="icon-button create-action" data-tooltip="New User" aria-label="New User">
                <i class="pi pi-plus"></i>
            </a>
        </div>

        @if (!Model.Any()) {
            <div class="empty-state">
                <strong>No users found.</strong>
                <span>Add a new record to begin.</span>
                <a asp-action="Create" class="primary-button">New User</a>
            </div>
        } else {
            <div class="dsm-rows">
@foreach (var item in Model) {
                <div class="row-shell dsm-search-row">
                    <article class="table-row">
                        <div>
                            <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                            <span>@Html.DisplayFor(modelItem => item.Email)</span>
                        </div>

                        <div class="row-metrics">
                            <span class="dsm-chip">@Html.DisplayFor(modelItem => item.Username)</span>
                            <span class="dsm-chip"><span class="muted-value">••••••</span></span>
                            <span class="dsm-chip"><span class="status-pill">@Html.DisplayFor(modelItem => item.Role)</span></span>
                        </div>

                        <div class="row-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details" aria-label="Details">
                                <i class="pi pi-eye"></i>
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit" aria-label="Edit">
                                <i class="pi pi-pencil"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete" aria-label="Delete">
                                <i class="pi pi-trash"></i>
                            </a>
                        </div>

                        <span class="row-chevron"><i class="pi pi-chevron-down"></i></span>
                    </article>

                    <section class="row-detail static-detail">
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Username)</span>
                            <strong>@Html.DisplayFor(modelItem => item.Username)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Password)</span>
                            <strong><span class="muted-value">••••••</span></strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Name)</span>
                            <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Email)</span>
                            <strong>@Html.DisplayFor(modelItem => item.Email)</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.Role)</span>
                            <strong><span class="status-pill">@Html.DisplayFor(modelItem => item.Role)</span></strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.IsActive)</span>
                            <strong>@if (item.IsActive == true) {
                                <span class="status-pill status-good">Active</span>
                            } else {
                                <span class="status-pill">Inactive</span>
                            }</strong>
                        </div>
                        <div>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <strong>@Html.DisplayFor(modelItem => item.CreatedAt)</strong>
                        </div>
                    </section>
                </div>
}
            </div>
        }
    </section>
</section>
