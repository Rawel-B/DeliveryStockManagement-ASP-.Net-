@model DSM.Models.Shipping

@{
    ViewData["Title"] = "Update Shipping";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Edit" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <div>
                    <h2>Update Shipping</h2>
                    <p>Manage delivery records, carriers and tracking data.</p>
                </div>
            </div>

                        <input type="hidden" asp-for="Id" />

                        <label>
                            <span>@Html.DisplayNameFor(model => model.OrderId)</span>
                            <input asp-for="OrderId" type="number" step="any" placeholder="Enter orderid" />
                            <span asp-validation-for="OrderId" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CarrierId)</span>
                            <input asp-for="CarrierId" type="number" step="any" placeholder="Enter carrierid" />
                            <span asp-validation-for="CarrierId" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.DeliveryDate)</span>
                            <input asp-for="DeliveryDate" placeholder="Enter deliverydate" />
                            <span asp-validation-for="DeliveryDate" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.ReceiptDate)</span>
                            <input asp-for="ReceiptDate" placeholder="Enter receiptdate" />
                            <span asp-validation-for="ReceiptDate" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Cost)</span>
                            <input asp-for="Cost" type="number" step="any" placeholder="Enter cost" />
                            <span asp-validation-for="Cost" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Status)</span>
                            <input asp-for="Status" placeholder="Enter status" />
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.ShippingAddress)</span>
                            <textarea asp-for="ShippingAddress" placeholder="Enter shippingaddress"></textarea>
                            <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.TrackingNumber)</span>
                            <input asp-for="TrackingNumber" placeholder="Enter trackingnumber" />
                            <span asp-validation-for="TrackingNumber" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Remark)</span>
                            <textarea asp-for="Remark" placeholder="Enter remark"></textarea>
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" placeholder="Enter createdat" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" placeholder="Enter updatedat" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
