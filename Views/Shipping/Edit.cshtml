@model DSM.Models.Shipping
@{ ViewData["Title"] = "Update Delivery"; }
<section class="workspace-grid"><div class="form-backdrop inline-form-backdrop"><form asp-action="Edit" class="workspace-form modal-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
    <div class="form-head"><a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back"><i class="pi pi-arrow-left"></i></a><div><h2>Update Delivery</h2><p>Plan delivery, carrier, tracking and workflow status.</p></div></div>
    <label><span>Order</span><select asp-for="OrderId" asp-items="ViewBag.Orders"><option value="">Select order</option></select><span asp-validation-for="OrderId" class="text-danger"></span></label>
    <label><span>Carrier</span><select asp-for="CarrierId" asp-items="ViewBag.Carriers"><option value="">Select carrier</option></select><span asp-validation-for="CarrierId" class="text-danger"></span></label>
    <label><span>Delivery date</span><input asp-for="DeliveryDate" type="datetime-local" /><span asp-validation-for="DeliveryDate" class="text-danger"></span></label>
    <label><span>Cost</span><input asp-for="Cost" type="number" min="0" step="0.01" /><span asp-validation-for="Cost" class="text-danger"></span></label>
    <label><span>Shipping address</span><input asp-for="ShippingAddress" placeholder="Enter shipping address" /><span asp-validation-for="ShippingAddress" class="text-danger"></span></label>
    <label><span>Tracking number</span><input asp-for="TrackingNumber" placeholder="Enter tracking number" /></label>
    <label><span>Remark</span><textarea asp-for="Remark" placeholder="Enter remark"></textarea></label>
    <div class="form-actions"><a asp-action="Index" class="secondary-button">Cancel</a><button type="submit" class="primary-button">Update</button></div>
</form></div></section>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
