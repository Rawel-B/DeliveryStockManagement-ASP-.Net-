@model DSM.Models.Shipping

@{
    ViewData["Title"] = "Delete Shipping";
}

<section class="workspace-grid">
    <section class="confirm-toast delete-card">
        <span>Confirm deletion</span>
        <h2>Delete this Shipping?</h2>
        <p class="delete-warning">This action will remove the selected record.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.OrderId)</span>
                    <strong>@Html.DisplayFor(model => model.OrderId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CarrierId)</span>
                    <strong>@Html.DisplayFor(model => model.CarrierId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.DeliveryDate)</span>
                    <strong>@Html.DisplayFor(model => model.DeliveryDate)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.ReceiptDate)</span>
                    <strong>@Html.DisplayFor(model => model.ReceiptDate)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Cost)</span>
                    <strong class="money-value">@Html.DisplayFor(model => model.Cost)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Status)</span>
                    <strong class="@DsmControllerUtilities.StatusPillClass(Model.Status)">@DsmControllerUtilities.DisplayLabel(Model.Status)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.ShippingAddress)</span>
                    <strong>@Html.DisplayFor(model => model.ShippingAddress)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.TrackingNumber)</span>
                    <strong>@Html.DisplayFor(model => model.TrackingNumber)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Remark)</span>
                    <strong>@Html.DisplayFor(model => model.Remark)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.UpdatedAt)</strong>
                </div>
        </section>

        <form asp-action="Delete" class="form-actions">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="secondary-button">Cancel</a>
            <button type="submit" class="primary-button danger-submit">Delete</button>
        </form>
    </section>
</section>
