@model IEnumerable<DSM.Models.Shipping>
@{ ViewData["Title"] = "Deliveries"; }
<section class="workspace-grid"><section class="workspace-table dsm-list-panel" data-dsm-list><div class="table-head"><div><h2>Deliveries</h2><p>Plan delivery, carrier, tracking and workflow status.</p></div><div class="table-filters"><span class="filter-leading-icon"><i class="pi pi-search"></i></span><input class="dsm-search-input" type="search" placeholder="Search deliveries" /><button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear"><i class="pi pi-times"></i></button></div><a asp-action="Create" class="icon-button create-action" data-tooltip="New Delivery"><i class="pi pi-plus"></i></a></div>
@if (!Model.Any()) { <div class="empty-state"><strong>No deliveries found.</strong><span>Create deliveries for validated orders.</span><a asp-action="Create" class="primary-button">New Delivery</a></div> } else { <div class="dsm-rows">@foreach (var item in Model) { <div class="row-shell dsm-search-row"><article class="table-row"><div><strong>@(item.Order?.OrderNumber ?? item.OrderNumber)</strong><span>@(item.Carrier?.Name ?? "No carrier") - @item.Status</span></div><div class="row-metrics"><span class="dsm-chip">@item.DeliveryDate</span><span class="dsm-chip">@item.Cost.ToString("0.00")</span></div><div class="row-actions"><a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details"><i class="pi pi-eye"></i></a><a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit"><i class="pi pi-pencil"></i></a><a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete"><i class="pi pi-trash"></i></a></div><span class="row-chevron"><i class="pi pi-chevron-down"></i></span></article><section class="row-detail static-detail"><div><span>Tracking</span><strong>@(item.TrackingNumber ?? "No tracking")</strong></div><div><span>Address</span><strong>@(item.ShippingAddress ?? "No address")</strong></div><div><span>Receipt</span><strong>@item.ReceiptDate</strong></div><div><span>Remark</span><strong>@(item.Remark ?? "No remark")</strong></div></section></div> }</div> }
</section></section>
