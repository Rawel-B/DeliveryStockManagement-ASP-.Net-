@model DSM.Models.Customer

@{
    ViewData["Title"] = "New Customer";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Create" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <div>
                    <h2>New Customer</h2>
                    <p>Manage customers, contact details and order relationships.</p>
                </div>
            </div>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Name)</span>
                            <input asp-for="Name" placeholder="Enter name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Email)</span>
                            <input asp-for="Email" type="email" placeholder="Enter email" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Address)</span>
                            <textarea asp-for="Address" placeholder="Enter address"></textarea>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Phone)</span>
                            <input asp-for="Phone" placeholder="Enter phone" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" placeholder="Enter createdat" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" placeholder="Enter updatedat" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
