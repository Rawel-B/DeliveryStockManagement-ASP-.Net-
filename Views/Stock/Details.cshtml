@model DSM.Models.Stock

@{
    ViewData["Title"] = "Stock Details";
}

<section class="workspace-grid">
    <section class="confirm-toast details-card">
        <span>Stock details</span>
        <h2>@Html.DisplayFor(model => model.Product)</h2>
        <p class="delete-warning">Track stock levels, locations and availability.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.Product)</span>
                    <strong>@Html.DisplayFor(model => model.Product)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.ProductRef)</span>
                    <strong>@Html.DisplayFor(model => model.ProductRef)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.LocationId)</span>
                    <strong>@Html.DisplayFor(model => model.LocationId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Location)</span>
                    <strong>@Html.DisplayFor(model => model.Location)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Quantity)</span>
                    <strong>@Html.DisplayFor(model => model.Quantity)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.LastReceiptDate)</span>
                    <strong>@Html.DisplayFor(model => model.LastReceiptDate)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.UpdatedAt)</strong>
                </div>
        </section>

        <div class="form-actions">
            <a asp-action="Index" class="secondary-button">Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="primary-button">Edit</a>
        </div>
    </section>
</section>
