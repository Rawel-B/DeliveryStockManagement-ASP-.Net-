@model DSM.Models.Stock

@{
    ViewData["Title"] = "New Stock";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Create" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back"><i class="pi pi-arrow-left"></i></a>
                <div><h2>New Stock</h2><p>Track stock levels, locations and availability.</p></div>
            </div>
            <label><span>Product</span><input asp-for="Product" placeholder="Enter product" /><span asp-validation-for="Product" class="text-danger"></span></label>
            <label><span>Product reference</span><input asp-for="ProductRef" placeholder="Enter product reference" /></label>
            <label><span>Location</span><select asp-for="LocationId" asp-items="ViewBag.Locations"><option value="">No location</option></select></label>
            <label><span>Quantity</span><input asp-for="Quantity" type="number" min="0" /></label>
            <div class="form-actions"><a asp-action="Index" class="secondary-button">Cancel</a><button type="submit" class="primary-button">Create</button></div>
        </form>
    </div>
</section>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
