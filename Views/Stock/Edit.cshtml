@model DSM.Models.Stock

@{
    ViewData["Title"] = "Update Stock";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Edit" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <div>
                    <h2>Update Stock</h2>
                    <p>Track stock levels, locations and availability.</p>
                </div>
            </div>

                        <input type="hidden" asp-for="Id" />

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Product)</span>
                            <input asp-for="Product" placeholder="Enter product" />
                            <span asp-validation-for="Product" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.ProductRef)</span>
                            <input asp-for="ProductRef" placeholder="Enter productref" />
                            <span asp-validation-for="ProductRef" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.LocationId)</span>
                            <input asp-for="LocationId" type="number" step="any" placeholder="Enter locationid" />
                            <span asp-validation-for="LocationId" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Location)</span>
                            <input asp-for="Location" placeholder="Enter location" />
                            <span asp-validation-for="Location" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Quantity)</span>
                            <input asp-for="Quantity" type="number" step="any" placeholder="Enter quantity" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.LastReceiptDate)</span>
                            <input asp-for="LastReceiptDate" placeholder="Enter lastreceiptdate" />
                            <span asp-validation-for="LastReceiptDate" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" placeholder="Enter createdat" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" placeholder="Enter updatedat" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
