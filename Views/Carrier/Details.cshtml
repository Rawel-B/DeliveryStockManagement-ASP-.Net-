@model DSM.Models.Carrier

@{
    ViewData["Title"] = "Carrier Details";
}

<section class="workspace-grid">
    <section class="confirm-toast details-card">
        <span>Carrier details</span>
        <h2>@Html.DisplayFor(model => model.Name)</h2>
        <p class="delete-warning">Manage delivery carriers, ratings and activity status.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.Name)</span>
                    <strong>@Html.DisplayFor(model => model.Name)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Phone)</span>
                    <strong>@Html.DisplayFor(model => model.Phone)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Rating)</span>
                    <strong class="status-pill status-rating">@(Model?.Rating ?? 0)/5</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.IsActive)</span>
                    @if (Model?.IsActive == true) {
                        <strong class="status-pill status-good">Active</strong>
                    } else {
                        <strong class="status-pill">Inactive</strong>
                    }
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.ShippingIds)</span>
                    <strong>@Html.DisplayFor(model => model.ShippingIds)</strong>
                </div>
        </section>

        <div class="form-actions">
            <a asp-action="Index" class="secondary-button">Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="primary-button">Edit</a>
        </div>
    </section>
</section>
