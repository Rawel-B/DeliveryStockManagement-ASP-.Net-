@model DSM.Models.Carrier

@{
    ViewData["Title"] = "Details";
}

@* Generated scaffolded Details view kept and cleaned up with Bootstrap styling. *@
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>Details</h1>
            <h4 class="text-muted">Carrier</h4>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-warning">Edit</a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
    <hr />

    <div class="card shadow-sm">
        <div class="card-body">
            <dl class="row mb-0">
                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Phone)
                </dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrWhiteSpace(Model?.Phone) ? "No phone" : Model.Phone)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Rating)
                </dt>
                <dd class="col-sm-9">
                    <span class="badge bg-warning text-dark">@(Model?.Rating ?? 0)/5</span>
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.IsActive)
                </dt>
                <dd class="col-sm-9">
                    @if (Model?.IsActive == true) {
                        <span class="badge bg-success">Active</span>
                    } else {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.ShippingIds)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.ShippingIds)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.CreatedAt)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.CreatedAt)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.UpdatedAt)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.UpdatedAt)
                </dd>
            </dl>
        </div>
    </div>
</div>
