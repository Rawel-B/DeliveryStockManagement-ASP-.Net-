@model DSM.Models.Carrier

@{
    ViewData["Title"] = "Edit";
}

@* Generated scaffolded Edit view kept and customized to mirror the Angular carrier update form. *@
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1>Edit</h1>
            <h4 class="text-muted">Carrier</h4>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
    <hr />
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="control-label"></label>
                            <input asp-for="Name" class="form-control" placeholder="Carrier name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Phone" class="control-label"></label>
                            <input asp-for="Phone" class="form-control" placeholder="Phone number" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Rating" class="control-label"></label>
                            <input asp-for="Rating" class="form-control" type="number" min="0" max="5" step="0.1" />
                            <span asp-validation-for="Rating" class="text-danger"></span>
                        </div>

                        <div class="form-group form-check mb-3">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label"></label>
                            <span asp-validation-for="IsActive" class="text-danger"></span>
                        </div>

                        <div class="border rounded p-3 mb-3 bg-light">
                            <small class="text-muted d-block mb-2">Generated scaffold fields kept for traceability.</small>
                            <div class="form-group mb-3">
                                <label asp-for="ShippingIds" class="control-label"></label>
                                <input asp-for="ShippingIds" class="form-control" />
                                <span asp-validation-for="ShippingIds" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="CreatedAt" class="control-label"></label>
                                <input asp-for="CreatedAt" class="form-control" />
                                <span asp-validation-for="CreatedAt" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="UpdatedAt" class="control-label"></label>
                                <input asp-for="UpdatedAt" class="form-control" />
                                <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="form-group d-flex gap-2">
                            <input type="submit" value="Save" class="btn btn-primary" />
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
