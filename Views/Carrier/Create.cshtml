@model DSM.Models.Carrier

@{
    ViewData["Title"] = "New Carrier";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Create" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back"><i class="pi pi-arrow-left"></i></a>
                <div>
                    <h2>New Carrier</h2>
                    <p>Create a new record.</p>
                </div>
            </div>

            <label>
                <span>Name</span>
                <input asp-for="Name" type="text" placeholder="Enter name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </label>

            <label>
                <span>Phone</span>
                <input asp-for="Phone" type="text" placeholder="Enter phone" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </label>

            <label>
                <span>Rating</span>
                <input asp-for="Rating" type="number" step="0.01" min="0" placeholder="Enter rating" />
                <span asp-validation-for="Rating" class="text-danger"></span>
            </label>

            <label class="toggle-line">
                <input asp-for="IsActive" />
                <span>Active</span>
            </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
