@model DSM.Models.Carrier

@{
    ViewData["Title"] = "Delete";
}

@* Generated scaffolded Delete view kept and styled for confirmation. *@
<div class="container mt-4">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h1 class="h4 mb-0">Delete</h1>
        </div>
        <div class="card-body">
            <h3>Are you sure you want to delete this?</h3>
            <h4 class="text-muted">DSM.Models.Carrier</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Name)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.Name)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Phone)
                </dt>
                <dd class="col-sm-9">
                    @(string.IsNullOrWhiteSpace(Model?.Phone) ? "No phone" : Model.Phone)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.Rating)
                </dt>
                <dd class="col-sm-9">
                    <span class="badge bg-warning text-dark">@(Model?.Rating ?? 0)/5</span>
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.IsActive)
                </dt>
                <dd class="col-sm-9">
                    @if (Model?.IsActive == true) {
                        <span class="badge bg-success">Active</span>
                    } else {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.ShippingIds)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.ShippingIds)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.CreatedAt)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.CreatedAt)
                </dd>

                <dt class="col-sm-3">
                    @Html.DisplayNameFor(model => model.UpdatedAt)
                </dt>
                <dd class="col-sm-9">
                    @Html.DisplayFor(model => model.UpdatedAt)
                </dd>
            </dl>
            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>
