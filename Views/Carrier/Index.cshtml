@model IEnumerable<DSM.Models.Carrier>

@{
    ViewData["Title"] = "Index";
    var selectedStatus = ViewBag.Status as string ?? "";
}

@* Generated scaffolded Index view kept and customized to mirror the Angular carriers section. *@
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="mb-1">Carriers</h1>
            <p class="text-muted mb-0">Manage delivery carriers, ratings and activity status.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">+ Create New</a>
    </div>

    <form asp-action="Index" method="get" class="row g-2 align-items-center mb-4">
        <div class="col-md-6">
            <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search carriers" />
        </div>
        <div class="col-md-3">
            <select name="status" class="form-select">
                <option value="">All</option>
                <option value="active" selected="@(selectedStatus == "active" ? "selected" : null)">Active</option>
                <option value="inactive" selected="@(selectedStatus == "inactive" ? "selected" : null)">Inactive</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-dark">Filter</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Any()) {
        <div class="alert alert-info">No carriers found.</div>
    } else {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>
                            @Html.DisplayNameFor(model => model.Name)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Phone)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.Rating)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.IsActive)
                        </th>
                        <th>
                            @Html.DisplayNameFor(model => model.ShippingIds)
                        </th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
@foreach (var item in Model) {
                    <tr>
                        <td>
                            <strong>@Html.DisplayFor(modelItem => item.Name)</strong>
                        </td>
                        <td>
                            <span class="text-muted">@(string.IsNullOrWhiteSpace(item.Phone) ? "No phone" : item.Phone)</span>
                        </td>
                        <td>
                            <span class="badge bg-warning text-dark">@Html.DisplayFor(modelItem => item.Rating)/5</span>
                        </td>
                        <td>
                            @if (item.IsActive == true) {
                                <span class="badge bg-success">Active</span>
                            } else {
                                <span class="badge bg-secondary">Inactive</span>
                            }
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.ShippingIds)
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
}
                </tbody>
            </table>
        </div>
    }
</div>
