@model DSM.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot password";
    Layout = "_AuthLayout";

    var showTicket = !string.IsNullOrWhiteSpace(Model.Error) || !string.IsNullOrWhiteSpace(Model.TicketMessage);
    var ticketFormClass = showTicket ? "auth-form access-ticket-form" : "auth-form access-ticket-form hidden";
}

<main class="auth-page compact-auth-page">
    <section class="auth-card" aria-label="Forgot password form">
        <div class="auth-card-brand">
            <img class="brand-logo compact-brand-logo" src="~/logo-mark.svg" alt="Delivery Stock Management" />
            <strong>Delivery Stock Management</strong>
        </div>

        <div class="auth-card-header">
            <h2>Forgot password</h2>
        </div>

        <form asp-action="ForgotPassword" method="post" class="auth-form" novalidate>
            <label>
                <span>Email</span>
                <input asp-for="Email" autocomplete="email" />
            </label>
            <span asp-validation-for="Email" class="field-error"></span>

            @if (!string.IsNullOrWhiteSpace(Model.Message)) {
                <p class="form-success">@Model.Message</p>
            }

            @if (!string.IsNullOrWhiteSpace(Model.Error)) {
                <p class="form-error">@Model.Error</p>
                <button class="secondary-button" type="button" data-auth-ticket-toggle>
                    Open access ticket
                </button>
            }

            <button class="primary-button" type="submit">Reset password</button>
        </form>

        <form asp-action="CreatePublicTicket" method="post" class="@ticketFormClass" data-auth-ticket-form novalidate>
            <input asp-for="Email" type="hidden" />

            <label>
                <span>Email</span>
                <input asp-for="TicketEmail" autocomplete="email" />
            </label>
            <span asp-validation-for="TicketEmail" class="field-error"></span>

            <label>
                <span>Type</span>
                <select asp-for="TicketCategory">
                    <option value="access">Access</option>
                    <option value="accountActivation">Account Activation</option>
                </select>
            </label>

            <label>
                <span>Issue</span>
                <textarea asp-for="TicketDescription"></textarea>
            </label>
            <span asp-validation-for="TicketDescription" class="field-error"></span>

            @if (!string.IsNullOrWhiteSpace(Model.TicketMessage)) {
                <p class="form-success">@Model.TicketMessage</p>
            }

            <button class="primary-button" type="submit">Send ticket</button>
        </form>

        <p class="auth-switch"><a asp-action="SignIn">Back to sign in</a></p>
    </section>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
