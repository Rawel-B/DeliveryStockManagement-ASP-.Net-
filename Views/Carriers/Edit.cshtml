@model DSM.Models.Carrier

@{
    ViewData["Title"] = "Edit";
}

@* Generated scaffolded Edit view kept and restyled to mirror the original Angular modal form. *@
<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Edit" class="workspace-form modal-form">
            <div class="form-head">
                <a asp-action="Index" class="icon-button" aria-label="Back" data-tooltip="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <h2>Edit Carrier</h2>
            </div>

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="Id" />
                        <label>
                            <span>@Html.DisplayNameFor(model => model.Name)</span>
                            <input asp-for="Name" class="form-control" placeholder="Name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Phone)</span>
                            <input asp-for="Phone" class="form-control" placeholder="Phone" />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Rating)</span>
                            <input asp-for="Rating" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="Rating" class="text-danger"></span>
                        </label>

                        <label class="active-toggle">
                            <input asp-for="IsActive" />
                            <span></span>
                            <strong>@Html.DisplayNameFor(model => model.IsActive)</strong>
                        </label>
                        <span asp-validation-for="IsActive" class="text-danger"></span>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.ShippingIds)</span>
                            <input asp-for="ShippingIds" class="form-control" placeholder="Shipping IDs" />
                            <span asp-validation-for="ShippingIds" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" class="form-control" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" class="form-control" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <button class="primary-button" type="submit">Save</button>
                <a asp-action="Index" class="secondary-button">Back to List</a>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
