@model DSM.Models.Order

@{
    ViewData["Title"] = "Order Details";
}

<section class="workspace-grid">
    <section class="confirm-toast details-card">
        <span>Order details</span>
        <h2>@Html.DisplayFor(model => model.OrderNumber)</h2>
        <p class="delete-warning">Track orders, customers, suppliers and workflow status.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.CustomerId)</span>
                    <strong>@Html.DisplayFor(model => model.CustomerId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.SupplierId)</span>
                    <strong>@Html.DisplayFor(model => model.SupplierId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.OrderDate)</span>
                    <strong>@Html.DisplayFor(model => model.OrderDate)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Status)</span>
                    <strong class="@DsmControllerUtilities.StatusPillClass(Model.Status)">@DsmControllerUtilities.DisplayLabel(Model.Status)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.TotalAmount)</span>
                    <strong class="money-value">@Html.DisplayFor(model => model.TotalAmount)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.OrderNumber)</span>
                    <strong>@Html.DisplayFor(model => model.OrderNumber)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Remark)</span>
                    <strong>@Html.DisplayFor(model => model.Remark)</strong>
                </div>
                <div class="detail-wide">
                    <span>Products</span>
                    @if (Model.Products == null || !Model.Products.Any()) {
                        <strong>No products</strong>
                    } else {
                        <div class="product-lines details-product-lines">
                            @foreach (var product in Model.Products) {
                                <div class="product-line">
                                    <span>@product.ProductName</span>
                                    <span>@(string.IsNullOrWhiteSpace(product.ProductRef) ? "No reference" : product.ProductRef)</span>
                                    <span>@product.Quantity x @product.PricePerUnit.ToString("0.00")</span>
                                    <span>@product.SubTotal.ToString("0.00")</span>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.UpdatedAt)</strong>
                </div>
        </section>

        <div class="form-actions">
            <a asp-action="Index" class="secondary-button">Back</a>
            <a asp-action="Edit" asp-route-id="@Model?.Id" class="primary-button">Edit</a>
        </div>
    </section>
</section>
