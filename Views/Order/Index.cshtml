@model IEnumerable<DSM.Models.Order>
@{
    ViewData["Title"] = "Orders";
    var workflow = DsmControllerUtilities.OrderWorkflowStatuses();
}

<section class="workspace-grid">
    <section class="workspace-table dsm-list-panel" data-dsm-list>
        <div class="table-head">
            <div><h2>Orders</h2></div>
            <div class="table-filters">
                <span class="filter-leading-icon"><i class="pi pi-search"></i></span>
                <input class="dsm-search-input" type="search" placeholder="Search orders" />
                <button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear"><i class="pi pi-times"></i></button>
            </div>
            <a asp-action="Create" class="icon-button create-action" data-tooltip="New Order"><i class="pi pi-plus"></i></a>
        </div>

        @if (!Model.Any()) {
            <div class="dsm-rows"></div>
        } else {
            <div class="dsm-rows">
                @foreach (var item in Model) {
                    var nextStatus = DsmControllerUtilities.NextOrderStatus(item.Status);
                    <div class="row-shell dsm-search-row">
                        <article class="table-row order-row phase-row">
                            <div>
                                <strong>@item.OrderNumber</strong>
                                <span>@(item.Customer?.Name ?? item.CustomerName) - @item.TotalAmount.ToString("0.00")</span>
                            </div>

                            <div class="order-status-stack">
                                <span class="@DsmControllerUtilities.StatusPillClass(item.Status)">@DsmControllerUtilities.DisplayLabel(item.Status)</span>
                                <div class="phase-control" aria-label="Order status workflow">
                                    <div class="phase-track">
                                        @foreach (var status in workflow) {
                                            <span class="@DsmControllerUtilities.PhaseStepClass(item.Status, status, workflow)">
                                                <i></i>
                                                <small>@DsmControllerUtilities.DisplayLabel(status)</small>
                                            </span>
                                        }
                                    </div>
                                    <div class="phase-actions">
                                        @if (nextStatus != null) {
                                            <form asp-action="SetOrderStatus" method="post" class="inline-phase-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="@nextStatus" />
                                                <button class="phase-action" type="submit">
                                                    <i class="@DsmControllerUtilities.OrderNextActionIcon(item.Status)"></i>
                                                    <span>@DsmControllerUtilities.OrderNextActionLabel(item.Status)</span>
                                                </button>
                                            </form>
                                        }
                                        @if (item.Status == OrderStatus.validated) {
                                            <a asp-controller="Shipping" asp-action="Create" asp-route-orderId="@item.Id" class="phase-action">
                                                <i class="pi pi-truck"></i>
                                                <span>Create Delivery</span>
                                            </a>
                                        }
                                        @if (DsmControllerUtilities.OrderCanCancel(item.Status)) {
                                            <form asp-action="SetOrderStatus" method="post" class="inline-phase-form">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="hidden" name="status" value="cancelled" />
                                                <button class="phase-action danger-action" type="submit">
                                                    <i class="pi pi-ban"></i>
                                                    <span>Cancel Order</span>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="row-actions">
                                <a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details"><i class="pi pi-eye"></i></a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit"><i class="pi pi-pencil"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete"><i class="pi pi-trash"></i></a>
                            </div>
                            <span class="row-chevron"><i class="pi pi-chevron-down"></i></span>
                        </article>

                        <section class="row-detail static-detail">
                            <div><span>Customer</span><strong>@(item.Customer?.Name ?? item.CustomerName)</strong></div>
                            <div><span>Supplier</span><strong>@(item.Supplier?.Name ?? item.SupplierName ?? "No supplier")</strong></div>
                            <div><span>Status</span><strong class="@DsmControllerUtilities.StatusPillClass(item.Status)">@DsmControllerUtilities.DisplayLabel(item.Status)</strong></div>
                            <div><span>Total</span><strong>@item.TotalAmount.ToString("0.00")</strong></div>
                            <div class="detail-wide"><span>Products</span><strong>@(item.Products == null || !item.Products.Any() ? "No products" : string.Join(" | ", item.Products.Select(p => $"{p.ProductName}" + (string.IsNullOrWhiteSpace(p.ProductRef) ? "" : $" ({p.ProductRef})") + $" - {p.Quantity} x {p.PricePerUnit:0.00}")))</strong></div>
                            <div><span>Remark</span><strong>@(item.Remark ?? "No remark")</strong></div>
                        </section>
                    </div>
                }
            </div>
        }
    </section>
</section>
