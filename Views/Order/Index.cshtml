@model IEnumerable<DSM.Models.Order>
@{ ViewData["Title"] = "Orders"; }
<section class="workspace-grid"><section class="workspace-table dsm-list-panel" data-dsm-list>
<div class="table-head"><div><h2>Orders</h2><p>Track orders, customers, suppliers and workflow status.</p></div><div class="table-filters"><span class="filter-leading-icon"><i class="pi pi-search"></i></span><input class="dsm-search-input" type="search" placeholder="Search orders" /><button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear"><i class="pi pi-times"></i></button></div><a asp-action="Create" class="icon-button create-action" data-tooltip="New Order"><i class="pi pi-plus"></i></a></div>
@if (!Model.Any()) { <div class="empty-state"><strong>No orders found.</strong><span>Create an order from customer, supplier and stock products.</span><a asp-action="Create" class="primary-button">New Order</a></div> } else { <div class="dsm-rows">
@foreach (var item in Model) { <div class="row-shell dsm-search-row"><article class="table-row order-row"><div><strong>@item.OrderNumber</strong><span>@(item.Customer?.Name ?? item.CustomerName) - @item.TotalAmount.ToString("0.00")</span></div><div class="order-status-stack"><span class="status-pill">@item.Status</span></div><div class="row-actions"><a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details"><i class="pi pi-eye"></i></a><a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit"><i class="pi pi-pencil"></i></a><a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete"><i class="pi pi-trash"></i></a></div><span class="row-chevron"><i class="pi pi-chevron-down"></i></span></article><section class="row-detail static-detail"><div><span>Customer</span><strong>@(item.Customer?.Name ?? item.CustomerName)</strong></div><div><span>Supplier</span><strong>@(item.Supplier?.Name ?? item.SupplierName ?? "No supplier")</strong></div><div><span>Status</span><strong>@item.Status</strong></div><div><span>Total</span><strong>@item.TotalAmount.ToString("0.00")</strong></div><div class="detail-wide"><span>Products</span><strong>@(item.Products == null || !item.Products.Any() ? "No products" : string.Join(" | ", item.Products.Select(p => $"{p.ProductName}" + (string.IsNullOrWhiteSpace(p.ProductRef) ? "" : $" ({p.ProductRef})") + $" - {p.Quantity} x {p.PricePerUnit:0.00}")))</strong></div><div><span>Remark</span><strong>@(item.Remark ?? "No remark")</strong></div></section></div> }
</div> }
</section></section>
