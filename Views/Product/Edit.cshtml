@model DSM.Models.Product

@{
    ViewData["Title"] = "Update Product";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Edit" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <div>
                    <h2>Update Product</h2>
                    <p>Manage product lines, quantities and pricing.</p>
                </div>
            </div>

                        <input type="hidden" asp-for="Id" />

                        <label>
                            <span>@Html.DisplayNameFor(model => model.OrderId)</span>
                            <input asp-for="OrderId" type="number" step="any" placeholder="Enter orderid" />
                            <span asp-validation-for="OrderId" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.ProductName)</span>
                            <input asp-for="ProductName" placeholder="Enter productname" />
                            <span asp-validation-for="ProductName" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.ProductRef)</span>
                            <input asp-for="ProductRef" placeholder="Enter productref" />
                            <span asp-validation-for="ProductRef" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Quantity)</span>
                            <input asp-for="Quantity" type="number" step="any" placeholder="Enter quantity" />
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.PricePerUnit)</span>
                            <input asp-for="PricePerUnit" type="number" step="any" placeholder="Enter priceperunit" />
                            <span asp-validation-for="PricePerUnit" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.SubTotal)</span>
                            <input asp-for="SubTotal" type="number" step="any" placeholder="Enter subtotal" />
                            <span asp-validation-for="SubTotal" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" placeholder="Enter createdat" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" placeholder="Enter updatedat" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
