@model DSM.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<section class="workspace-grid">
    <section class="confirm-toast delete-card">
        <span>Confirm deletion</span>
        <h2>Delete this Product?</h2>
        <p class="delete-warning">This action will remove the selected record.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.OrderId)</span>
                    <strong>@Html.DisplayFor(model => model.OrderId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.ProductName)</span>
                    <strong>@Html.DisplayFor(model => model.ProductName)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.ProductRef)</span>
                    <strong>@Html.DisplayFor(model => model.ProductRef)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Quantity)</span>
                    <strong>@Html.DisplayFor(model => model.Quantity)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.PricePerUnit)</span>
                    <strong class="money-value">@Html.DisplayFor(model => model.PricePerUnit)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.SubTotal)</span>
                    <strong class="money-value">@Html.DisplayFor(model => model.SubTotal)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.UpdatedAt)</strong>
                </div>
        </section>

        <form asp-action="Delete" class="form-actions">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="secondary-button">Cancel</a>
            <button type="submit" class="primary-button danger-submit">Delete</button>
        </form>
    </section>
</section>
