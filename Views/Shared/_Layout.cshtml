@using System.Security.Claims
@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    string Active(string name) => controller == name.ToLowerInvariant() ? " active" : "";
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "User";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "user";
    var email = User.FindFirst(ClaimTypes.Email)?.Value ?? string.Empty;
    var isAdmin = string.Equals(role, "administrator", StringComparison.OrdinalIgnoreCase);
    var isManager = string.Equals(role, "manager", StringComparison.OrdinalIgnoreCase);
    var isUser = string.Equals(role, "user", StringComparison.OrdinalIgnoreCase);
    var toastMessage = TempData["ToastMessage"]?.ToString()
        ?? TempData["AuthMessage"]?.ToString()
        ?? TempData["ProfileMessage"]?.ToString()
        ?? TempData["Error"]?.ToString();
    var toastType = TempData["ToastType"]?.ToString() ?? (TempData["Error"] != null ? "error" : "success");
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Delivery Stock Management</title>
    <link rel="stylesheet" href="~/css/dsm-dashboard.css" asp-append-version="true" />
</head>
<body>
    <main class="workspace-page">
        <aside class="workspace-sidebar">
            <div class="sidebar-brand">
                <img class="brand-logo sidebar-brand-logo" src="~/logo-mark.svg" alt="Delivery Stock Management" />
                <span class="brand-separator"></span>
                <div class="brand-copy">
                    <strong>Delivery Stock Management</strong>
                </div>
            </div>

            <nav class="workspace-nav" aria-label="Workspace sections">
                @if (isAdmin || isManager) {
                    <section class="nav-group primary-group">
                        <a class="workspace-nav-link@(Active("Dashboard"))" href="/Dashboard">
                            <i class="pi pi-chart-line"></i>
                            <span>Dashboard</span>
                        </a>
                    </section>
                }

                @if (isAdmin || isManager || isUser) {
                    <section class="nav-group">
                        <h2>Operations</h2>
                        <div>
                            @if (isAdmin || isManager) {
                                <a class="workspace-nav-link@(Active("Order"))" href="/Order"><i class="pi pi-shopping-cart"></i><span>Orders</span></a>
                            }
                            <a class="workspace-nav-link@(Active("Shipping"))" href="/Shipping"><i class="pi pi-truck"></i><span>Deliveries</span></a>
                            @if (isAdmin || isManager) {
                                <a class="workspace-nav-link@(Active("Invoice"))" href="/Invoice"><i class="pi pi-file"></i><span>Invoices</span></a>
                            }
                        </div>
                    </section>
                }

                @if (isAdmin || isUser) {
                    <section class="nav-group">
                        <h2>Inventory</h2>
                        <div>
                            <a class="workspace-nav-link@(Active("Stock"))" href="/Stock"><i class="pi pi-box"></i><span>Stocks</span></a>
                            <a class="workspace-nav-link@(Active("Location"))" href="/Location"><i class="pi pi-map-marker"></i><span>Locations</span></a>
                        </div>
                    </section>
                }

                @if (isAdmin || isManager) {
                    <section class="nav-group">
                        <h2>CRM</h2>
                        <div>
                            <a class="workspace-nav-link@(Active("Customer"))" href="/Customer"><i class="pi pi-users"></i><span>Customers</span></a>
                            <a class="workspace-nav-link@(Active("Supplier"))" href="/Supplier"><i class="pi pi-building"></i><span>Suppliers</span></a>
                            <a class="workspace-nav-link@(Active("Carrier"))" href="/Carrier"><i class="pi pi-send"></i><span>Carriers</span></a>
                        </div>
                    </section>
                }

                @if (isAdmin) {
                    <section class="nav-group support-group">
                        <h2>Support</h2>
                        <div>
                            <a class="workspace-nav-link@(Active("User"))" href="/User"><i class="pi pi-lock"></i><span>Users</span></a>
                            <a class="workspace-nav-link@(Active("SupportTicket"))" href="/SupportTicket"><i class="pi pi-ticket"></i><span>Support</span></a>
                        </div>
                    </section>
                }
            </nav>
        </aside>

        <section class="workspace-main">
            <header class="workspace-header">
                <div class="page-title">
                    <h1>@ViewData["Title"]</h1>
                </div>
                <div class="header-actions">
                    <div class="account-menu" data-account-menu>
                        <button class="account-button" type="button" aria-label="Open profile menu" data-tooltip="Profile" aria-expanded="false" data-account-toggle>
                            <i class="pi pi-user" data-profile-icon-current></i>
                        </button>
                        <section class="account-dropdown" aria-label="Profile menu" data-account-dropdown>
                            <div class="account-dropdown-head">
                                <span class="profile-avatar small-profile-avatar"><i class="pi pi-user" data-profile-icon-current></i></span>
                                <div>
                                    <strong>@displayName</strong>
                                    <span class="account-role">@role</span>
                                    <small>@User.Identity?.Name</small>
                                    <small>@email</small>
                                </div>
                            </div>
                            <a class="account-profile-link" href="/Profile"><i class="pi pi-user-edit"></i><span>Profile</span></a>
                        </section>
                    </div>

                    <form asp-controller="Auth" asp-action="SignOut" method="post" class="signout-form">
                        @Html.AntiForgeryToken()
                        <button class="signout-button" type="submit" aria-label="Sign out" data-tooltip="Sign out">
                            <i class="pi pi-sign-out"></i>
                        </button>
                    </form>
                </div>
            </header>

            @if (!string.IsNullOrWhiteSpace(toastMessage)) {
                <section class="workspace-toast @(toastType == "error" ? "error-toast" : "")" role="status" data-dsm-toast>
                    <i class="@(toastType == "error" ? "pi pi-exclamation-triangle" : "pi pi-check")"></i>
                    <div>
                        <strong>@(toastType == "error" ? "Error" : "Success")</strong>
                        <p>@toastMessage</p>
                    </div>
                    <button type="button" data-toast-dismiss aria-label="Dismiss notification">
                        <i class="pi pi-times"></i>
                    </button>
                </section>
            }

            @RenderBody()
        </section>
    </main>

    <script src="~/js/dsm-dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
