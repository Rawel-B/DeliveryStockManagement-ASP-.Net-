@{
    var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
    string Active(string name) => controller == name.ToLowerInvariant() ? " active" : "";
    var displayName = User.FindFirst("DisplayName")?.Value ?? User.Identity?.Name ?? "Profile";
    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";
    var userEmail = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Delivery Stock Management</title>
    <link rel="stylesheet" href="~/css/dsm-dashboard.css" asp-append-version="true" />
</head>
<body>
    <main class="workspace-page">
        <aside class="workspace-sidebar">
            <div class="sidebar-brand">
                <span class="brand-logo-text">DSM</span>
                <span class="brand-separator"></span>
                <div class="brand-copy">
                    <strong>Delivery Stock Management</strong>
                </div>
            </div>

            <nav class="workspace-nav" aria-label="Workspace sections">
                <section class="nav-group primary-group">
                    <a class="workspace-nav-link@(Active("Dashboard"))" href="/Dashboard">
                        <i class="pi pi-chart-line"></i>
                        <span>Dashboard</span>
                    </a>
                </section>

                <section class="nav-group">
                    <h2>Operations</h2>
                    <div>
                        <a class="workspace-nav-link@(Active("Order"))" href="/Order">
                            <i class="pi pi-shopping-cart"></i>
                            <span>Orders</span>
                        </a>
                        <a class="workspace-nav-link@(Active("Shipping"))" href="/Shipping">
                            <i class="pi pi-truck"></i>
                            <span>Deliveries</span>
                        </a>
                        <a class="workspace-nav-link@(Active("Invoice"))" href="/Invoice">
                            <i class="pi pi-file"></i>
                            <span>Invoices</span>
                        </a>
                    </div>
                </section>

                <section class="nav-group">
                    <h2>Inventory</h2>
                    <div>
                        <a class="workspace-nav-link@(Active("Stock"))" href="/Stock">
                            <i class="pi pi-box"></i>
                            <span>Stocks</span>
                        </a>
                        <a class="workspace-nav-link@(Active("Product"))" href="/Product">
                            <i class="pi pi-tags"></i>
                            <span>Products</span>
                        </a>
                        <a class="workspace-nav-link@(Active("Location"))" href="/Location">
                            <i class="pi pi-map-marker"></i>
                            <span>Locations</span>
                        </a>
                    </div>
                </section>

                <section class="nav-group">
                    <h2>CRM</h2>
                    <div>
                        <a class="workspace-nav-link@(Active("Customer"))" href="/Customer">
                            <i class="pi pi-users"></i>
                            <span>Customers</span>
                        </a>
                        <a class="workspace-nav-link@(Active("Supplier"))" href="/Supplier">
                            <i class="pi pi-building"></i>
                            <span>Suppliers</span>
                        </a>
                        <a class="workspace-nav-link@(Active("Carrier"))" href="/Carrier">
                            <i class="pi pi-send"></i>
                            <span>Carriers</span>
                        </a>
                    </div>
                </section>

                <section class="nav-group support-group">
                    <h2>Support</h2>
                    <div>
                        <a class="workspace-nav-link@(Active("User"))" href="/User">
                            <i class="pi pi-lock"></i>
                            <span>Users</span>
                        </a>
                        <a class="workspace-nav-link@(Active("SupportTicket"))" href="/SupportTicket">
                            <i class="pi pi-ticket"></i>
                            <span>Support</span>
                        </a>
                    </div>
                </section>
            </nav>
        </aside>

        <section class="workspace-main">
            <header class="workspace-header">
                <div class="page-title">
                    <h1>@ViewData["Title"]</h1>
                </div>
                <div class="header-actions">
                    @if (User.Identity?.IsAuthenticated == true) {
                        <div class="account-menu">
                            <a class="account-button" href="/Profile" aria-label="Open profile" data-tooltip="Profile">
                                <i class="pi pi-user"></i>
                            </a>
                            <section class="account-dropdown" aria-label="Profile menu">
                                <div class="account-dropdown-head">
                                    <span class="profile-avatar small-profile-avatar"><i class="pi pi-user"></i></span>
                                    <div>
                                        <strong>@displayName</strong>
                                        <span class="account-role">@userRole</span>
                                        <small>@User.Identity.Name</small>
                                        <small>@userEmail</small>
                                    </div>
                                </div>
                                <a href="/Profile">
                                    <i class="pi pi-user-edit"></i>
                                    <span>Profile</span>
                                </a>
                            </section>
                        </div>
                        <a class="signout-button" href="/Auth/SignOut" aria-label="Sign out" data-tooltip="Sign out">
                            <i class="pi pi-sign-out"></i>
                        </a>
                    } else {
                        <a class="primary-button compact-header-button" href="/Auth/SignIn">Sign in</a>
                    }
                </div>
            </header>

            @RenderBody()
        </section>
    </main>

    <script src="~/js/dsm-dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
