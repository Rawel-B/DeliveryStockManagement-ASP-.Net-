@model DSM.Models.Invoice
@{ ViewData["Title"] = "New Invoice"; }
<section class="workspace-grid"><div class="form-backdrop inline-form-backdrop"><form asp-action="Create" class="workspace-form modal-form" novalidate>
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-head"><a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back"><i class="pi pi-arrow-left"></i></a><div><h2>New Invoice</h2><p>Create payment records against validated orders.</p></div></div>
    <label><span>Order</span><select asp-for="OrderId" asp-items="ViewBag.Orders"><option value="">Select order</option></select><span asp-validation-for="OrderId" class="text-danger"></span></label>
    <label><span>Method</span><select asp-for="Method" asp-items="Html.GetEnumSelectList<DSM.Models.InvoicingMethod>()"></select></label>
    <label><span>Amount</span><input asp-for="Amount" type="number" min="0.01" step="0.01" /></label>
    <label><span>Transaction reference</span><input asp-for="TransactionRef" placeholder="Auto-generated if empty" /></label>
    <label><span>Remark</span><textarea asp-for="Remark" placeholder="Enter remark"></textarea></label>
    <div class="form-actions"><a asp-action="Index" class="secondary-button">Cancel</a><button type="submit" class="primary-button">Create</button></div>
</form></div></section>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
