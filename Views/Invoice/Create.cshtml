@model DSM.Models.Invoice

@{
    ViewData["Title"] = "New Invoice";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Create" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <div>
                    <h2>New Invoice</h2>
                    <p>Manage payment records, amounts and invoice status.</p>
                </div>
            </div>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.OrderId)</span>
                            <input asp-for="OrderId" type="number" step="any" placeholder="Enter orderid" />
                            <span asp-validation-for="OrderId" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.InvoicingDate)</span>
                            <input asp-for="InvoicingDate" placeholder="Enter invoicingdate" />
                            <span asp-validation-for="InvoicingDate" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Status)</span>
                            <input asp-for="Status" placeholder="Enter status" />
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Method)</span>
                            <input asp-for="Method" placeholder="Enter method" />
                            <span asp-validation-for="Method" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Amount)</span>
                            <input asp-for="Amount" type="number" step="any" placeholder="Enter amount" />
                            <span asp-validation-for="Amount" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.TransactionRef)</span>
                            <input asp-for="TransactionRef" placeholder="Enter transactionref" />
                            <span asp-validation-for="TransactionRef" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Remark)</span>
                            <textarea asp-for="Remark" placeholder="Enter remark"></textarea>
                            <span asp-validation-for="Remark" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" placeholder="Enter createdat" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" placeholder="Enter updatedat" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
