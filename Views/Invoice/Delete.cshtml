@model DSM.Models.Invoice

@{
    ViewData["Title"] = "Delete Invoice";
}

<section class="workspace-grid">
    <section class="confirm-toast delete-card">
        <span>Confirm deletion</span>
        <h2>Delete this Invoice?</h2>
        <p class="delete-warning">This action will remove the selected record.</p>

        <section class="row-detail static-detail">
                <div>
                    <span>@Html.DisplayNameFor(model => model.OrderId)</span>
                    <strong>@Html.DisplayFor(model => model.OrderId)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.InvoicingDate)</span>
                    <strong>@Html.DisplayFor(model => model.InvoicingDate)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Status)</span>
                    <strong class="status-pill">@Html.DisplayFor(model => model.Status)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Method)</span>
                    <strong class="status-pill">@Html.DisplayFor(model => model.Method)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Amount)</span>
                    <strong class="money-value">@Html.DisplayFor(model => model.Amount)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.TransactionRef)</span>
                    <strong>@Html.DisplayFor(model => model.TransactionRef)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.Remark)</span>
                    <strong>@Html.DisplayFor(model => model.Remark)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.CreatedAt)</strong>
                </div>
                <div>
                    <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                    <strong>@Html.DisplayFor(model => model.UpdatedAt)</strong>
                </div>
        </section>

        <form asp-action="Delete" class="form-actions">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="secondary-button">Cancel</a>
            <button type="submit" class="primary-button danger-submit">Delete</button>
        </form>
    </section>
</section>
