@model IEnumerable<DSM.Models.Invoice>
@{ ViewData["Title"] = "Invoices"; }
<section class="workspace-grid"><section class="workspace-table dsm-list-panel" data-dsm-list><div class="table-head"><div><h2>Invoices</h2><p>Create payment records against validated orders.</p></div><div class="table-filters"><span class="filter-leading-icon"><i class="pi pi-search"></i></span><input class="dsm-search-input" type="search" placeholder="Search invoices" /><button class="icon-button" type="button" data-dsm-clear data-tooltip="Clear"><i class="pi pi-times"></i></button></div><a asp-action="Create" class="icon-button create-action" data-tooltip="New Invoice"><i class="pi pi-plus"></i></a></div>
@if (!Model.Any()) { <div class="empty-state"><strong>No invoices found.</strong><span>Create an invoice for an eligible order.</span><a asp-action="Create" class="primary-button">New Invoice</a></div> } else { <div class="dsm-rows">@foreach (var item in Model) { <div class="row-shell dsm-search-row"><article class="table-row"><div><strong>@(item.Order?.OrderNumber ?? item.OrderNumber)</strong><span>@item.Method - @item.Amount.ToString("0.00")</span></div><div class="row-metrics"><span class="status-pill">@item.Status</span><span class="dsm-chip">@item.InvoicingDate</span></div><div class="row-actions"><a asp-action="Details" asp-route-id="@item.Id" class="icon-button" data-tooltip="Details"><i class="pi pi-eye"></i></a><a asp-action="Edit" asp-route-id="@item.Id" class="icon-button" data-tooltip="Edit"><i class="pi pi-pencil"></i></a><a asp-action="Delete" asp-route-id="@item.Id" class="icon-button danger-action" data-tooltip="Delete"><i class="pi pi-trash"></i></a></div><span class="row-chevron"><i class="pi pi-chevron-down"></i></span></article><section class="row-detail static-detail"><div><span>Transaction</span><strong>@(item.TransactionRef ?? "No reference")</strong></div><div><span>Remark</span><strong>@(item.Remark ?? "No remark")</strong></div></section></div> }</div> }
</section></section>
