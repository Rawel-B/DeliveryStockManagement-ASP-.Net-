@model DSM.Models.Location

@{
    ViewData["Title"] = "New Location";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Create" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back"><i class="pi pi-arrow-left"></i></a>
                <div>
                    <h2>New Location</h2>
                    <p>Create a new record.</p>
                </div>
            </div>

            <label>
                <span>Name</span>
                <input asp-for="Name" type="text" placeholder="Enter name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </label>

            <label>
                <span>Code</span>
                <input asp-for="Code" type="text" placeholder="Enter code" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </label>

            <label>
                <span>Description</span>
                <textarea asp-for="Description" placeholder="Enter description"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Create</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
