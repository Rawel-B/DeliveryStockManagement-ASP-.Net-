@model DSM.Models.Location

@{
    ViewData["Title"] = "Update Location";
}

<section class="workspace-grid">
    <div class="form-backdrop inline-form-backdrop">
        <form asp-action="Edit" class="workspace-form modal-form" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-head">
                <a asp-action="Index" class="icon-button" data-tooltip="Back" aria-label="Back">
                    <i class="pi pi-arrow-left"></i>
                </a>
                <div>
                    <h2>Update Location</h2>
                    <p>Manage warehouse and storage locations.</p>
                </div>
            </div>

                        <input type="hidden" asp-for="Id" />

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Name)</span>
                            <input asp-for="Name" placeholder="Enter name" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Code)</span>
                            <input asp-for="Code" placeholder="Enter code" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.Description)</span>
                            <textarea asp-for="Description" placeholder="Enter description"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.CreatedAt)</span>
                            <input asp-for="CreatedAt" placeholder="Enter createdat" />
                            <span asp-validation-for="CreatedAt" class="text-danger"></span>
                        </label>

                        <label>
                            <span>@Html.DisplayNameFor(model => model.UpdatedAt)</span>
                            <input asp-for="UpdatedAt" placeholder="Enter updatedat" />
                            <span asp-validation-for="UpdatedAt" class="text-danger"></span>
                        </label>

            <div class="form-actions">
                <a asp-action="Index" class="secondary-button">Cancel</a>
                <button type="submit" class="primary-button">Save</button>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
